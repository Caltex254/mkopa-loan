generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  phone        String   @unique
  email        String   @unique
  passwordHash String
  role         String   @default("user")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  kyc            KYC?
  loanApps       LoanApplication[]
  payments       Payment[]
  notifications  Notification[]
  activityLogs   ActivityLog[]
  supportChats   SupportChat[]

  @@index([role])
  @@index([createdAt])
}

model KYC {
  id                 String   @id @default(cuid())
  userId             String   @unique
  legalName          String
  nationalId         String
  idFrontImage       String   @db.Text
  idBackImage        String   @db.Text
  residentialAddress String
  dateOfBirth        String
  status             String   @default("pending")
  loanLimit          Float    @default(0)
  verifiedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
}

model LoanProduct {
  id            String   @id @default(cuid())
  amount        Float
  processingFee Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LoanApplication {
  id              String   @id @default(cuid())
  userId          String
  loanAmount      Float
  processingFee   Float
  amountReceived  Float
  totalRepayment  Float
  repaymentDate   String
  status          String   @default("draft")
  activationPaid  Boolean  @default(false)
  activationRef   String?
  paymentRef      String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([status])
  @@index([userId])
  @@index([createdAt])
  @@index([status, createdAt])
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  applicationId String?
  transactionId String
  paymentRef    String
  phoneNumber   String
  amount        Float
  status        String   @default("pending")
  type          String   @default("activation")
  createdAt     DateTime @default(now())

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  application LoanApplication? @relation(fields: [applicationId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([applicationId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   String   @db.Text
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model SupportChat {
  id        String   @id @default(cuid())
  userId    String
  subject   String   @default("General Support")
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([userId])
  @@index([status])
  @@index([updatedAt])
}

model SupportMessage {
  id        String   @id @default(cuid())
  chatId    String
  senderId  String
  content   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  chat SupportChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, isRead])
  @@index([chatId, createdAt])
}
