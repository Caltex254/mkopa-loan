# ─────────────────────────────────────────────────────────────
# Vercel deployment hygiene — these directories/files are NOT
# needed for the Vercel deployment. They are local-only build
# artifacts, deploy packages, and Cloudflare tunnel binaries
# that would otherwise bloat every serverless function and push
# us past the 250 MB uncompressed size limit.
# ─────────────────────────────────────────────────────────────
/download/
/deploy-pkg-clean/
/upload/
/tool-results/
/agent-ctx/
/mini-services/
/examples/
/cloudflared
/cloudflared.yml
/mkopa-final-deploy.tar.gz
/deploy-pkg-clean.tar.gz
/deploy.tar.gz
*.tar.gz

# SQLite local dev DB (Neon is used in production)
/db/*.db
/db/*.db-journal

# Pterodactyl / Cloudflare tunnel deployment scripts (not needed on Vercel)
/deploy-pterodactyl.sh
/start-with-tunnel.sh
/start-wrapper.js
/deploy-server.js
/deploy.js
/docker-entrypoint.sh
/pterodactyl-egg.sh
/Dockerfile
/docker-compose.yml
/Caddyfile
/scripts/build-deploy-package.sh

# Local dev PID files
/.zscripts/dev.pid
/3000
.open-next/
open-next.config.ts
wrangler.jsonc
scripts/cf-
scripts/patch-prisma-
src/lib/fs-polyfill.ts
