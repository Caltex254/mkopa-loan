ion:150ms}.hover\\:bg-brand-700:hover{--tw-bg-opacity:1;background-color:rgb(29 78 216 / var(--tw-bg-opacity, 1))}.hover\\:bg-slate-200:hover{--tw-bg-opacity:1;background-color:rgb(226 232 240 / var(--tw-bg-opacity, 1))}.hover\\:text-brand-600:hover{--tw-text-opacity:1;color:rgb(37 99 235 / var(--tw-text-opacity, 1))}.hover\\:text-slate-600:hover{--tw-text-opacity:1;color:rgb(71 85 105 / var(--tw-text-opacity, 1))}.hover\\:shadow-md:hover{--tw-shadow:0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);--tw-shadow-colored:0 4px 6px -1px var(--tw-shadow-color), 0 2px 4px -2px var(--tw-shadow-color);box-shadow:var(--tw-ring-offset-shadow, 0 0 #0000), var(--tw-ring-shadow, 0 0 #0000), var(--tw-shadow)}@media (min-width: 640px){.sm\\:w-auto{width:auto}.sm\\:flex-row{flex-direction:row}}@media (min-width: 768px){.md\\:flex{display:flex}.md\\:grid-cols-3{grid-template-columns:repeat(3, minmax(0, 1fr))}.md\\:grid-cols-4{grid-template-columns:repeat(4, minmax(0, 1fr))}.md\\:text-6xl{font-size:3.75rem;line-height:1}}</style></head>\n<body class=\"bg-white text-slate-800 antialiased\">\n\n<!-- Nav -->\n<nav class=\"sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-slate-100 px-4 py-3\">\n  <div class=\"max-w-6xl mx-auto flex items-center justify-between\">\n    <div class=\"flex items-center gap-3\">\n      <div class=\"w-9 h-9 bg-brand-600 rounded-lg flex items-center justify-center text-white font-bold\">X</div>\n      <span class=\"font-bold text-slate-800 text-lg\">Xdigitex Pay</span>\n    </div>\n    <div class=\"hidden md:flex items-center gap-6 text-sm font-medium text-slate-600\">\n      <a href=\"#features\" class=\"hover:text-brand-600 transition-colors\">Features</a>\n      <a href=\"#pricing\" class=\"hover:text-brand-600 transition-colors\">Pricing</a>\n      <a href=\"https://pay.xdigitex.space/docs\" class=\"hover:text-brand-600 transition-colors\">Docs</a>\n    </div>\n    <div class=\"flex items-center gap-2\">\n      <a href=\"https://pay.xdigitex.space/login\" class=\"text-sm font-medium text-slate-600 hover:text-brand-600 px-4 py-2\">Sign In</a>\n      <a href=\"https://pay.xdigitex.space/register\" class=\"bg-brand-600 hover:bg-brand-700 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors\">Get Started</a>\n    </div>\n  </div>\n</nav>\n\n<!-- Hero -->\n<section class=\"max-w-6xl mx-auto px-4 py-20 text-center\">\n  <div class=\"inline-flex items-center gap-2 bg-blue-50 text-blue-700 text-xs font-semibold px-4 py-1.5 rounded-full mb-6 border border-blue-100\">\n    <span class=\"w-1.5 h-1.5 bg-blue-500 rounded-full animate-pulse\"></span> Trusted by merchants across Africa\n  </div>\n  <h1 class=\"text-5xl md:text-6xl font-extrabold text-slate-900 leading-tight mb-6\">\n    Accept Payments<br><span class=\"text-brand-600\">Across Africa</span>\n  </h1>\n  <p class=\"text-xl text-slate-500 max-w-2xl mx-auto mb-10\">\n    Card, mobile money, and crypto — all in one platform. Create pay links, manage your wallet, and get paid faster.\n  </p>\n  <div class=\"flex flex-col sm:flex-row items-center justify-center gap-4\">\n    <a href=\"https://pay.xdigitex.space/register\" class=\"bg-brand-600 hover:bg-brand-700 text-white text-base font-semibold px-8 py-4 rounded-xl transition-colors w-full sm:w-auto\">\n      Start for free →\n    </a>\n    <a href=\"https://pay.xdigitex.space/docs\" class=\"bg-slate-100 hover:bg-slate-200 text-slate-700 text-base font-semibold px-8 py-4 rounded-xl transition-colors w-full sm:w-auto\">\n      View API Docs\n    </a>\n  </div>\n</section>\n\n<!-- Stats -->\n<section class=\"border-y border-slate-100 py-10 bg-slate-50\">\n  <div class=\"max-w-4xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-6 text-center\">\n    <div><div class=\"text-3xl font-extrabold text-slate-800 mb-1\">12+</div><div class=\"text-sm text-slate-500\">Countries</div></div>\n    <div><div class=\"text-3xl font-extrabold text-slate-800 mb-1\">3</div><div class=\"text-sm text-slate-500\">Payment Methods</div></div>\n    <div><div class=\"text-3xl font-extrabold text-slate-800 mb-1\">99.9%</div><div class=\"text-sm text-slate-500\">Uptime</div></div>\n    <div><div class=\"text-3xl font-extrabold text-slate-800 mb-1\">Real-time</div><div class=\"text-sm text-slate-500\">Settlements</div></div>\n  </div>\n</section>\n\n<!-- Features -->\n<section id=\"features\" class=\"max-w-6xl mx-auto px-4 py-20\">\n  <div class=\"text-center mb-14\">\n    <h2 class=\"text-3xl font-extrabold text-slate-900 mb-3\">Everything you need to get paid</h2>\n    <p class=\"text-slate-500 text-lg max-w-xl mx-auto\">Built for African businesses. Works with the payment methods your customers already use.</p>\n  </div>\n  <div class=\"grid md:grid-cols-3 gap-6\">\n        <div class=\"bg-white border border-slate-100 rounded-2xl p-6 hover:shadow-md transition-shadow\">\n      <div class=\"w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center text-xl mb-4\">\n        <i class=\"fas fa-credit-card\"></i>\n      </div>\n      <h3 class=\"font-semibold text-slate-800 mb-2\">Card Payments</h3>\n      <p class=\"text-slate-500 text-sm\">Accept Visa, Mastercard and local cards securely with instant confirmation.</p>\n    </div>\n        <div class=\"bg-white border border-slate-100 rounded-2xl p-6 hover:shadow-md transition-shadow\">\n      <div class=\"w-12 h-12 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center text-xl mb-4\">\n        <i class=\"fas fa-mobile-screen-button\"></i>\n      </div>\n      <h3 class=\"font-semibold text-slate-800 mb-2\">Mobile Money</h3>\n      <p class=\"text-slate-500 text-sm\">M-Pesa, Airtel Money, MTN, and 30+ mobile networks across Africa.</p>\n    </div>\n        <div class=\"bg-white border border-slate-100 rounded-2xl p-6 hover:shadow-md transition-shadow\">\n      <div class=\"w-12 h-12 bg-amber-50 text-amber-600 rounded-xl flex items-center justify-center text-xl mb-4\">\n        <i class=\"fas fa-bitcoin-sign\"></i>\n      </div>\n      <h3 class=\"font-semibold text-slate-800 mb-2\">Crypto Payments</h3>\n      <p class=\"text-slate-500 text-sm\">Accept USDT and other major cryptocurrencies via Binance Pay.</p>\n    </div>\n        <div class=\"bg-white border border-slate-100 rounded-2xl p-6 hover:shadow-md transition-shadow\">\n      <div class=\"w-12 h-12 bg-purple-50 text-purple-600 rounded-xl flex items-center justify-center text-xl mb-4\">\n        <i class=\"fas fa-link\"></i>\n      </div>\n      <h3 class=\"font-semibold text-slate-800 mb-2\">Pay Links</h3>\n      <p class=\"text-slate-500 text-sm\">Create shareable payment links in seconds. No code required.</p>\n    </div>\n        <div class=\"bg-white border border-slate-100 rounded-2xl p-6 hover:shadow-md transition-shadow\">\n      <div class=\"w-12 h-12 bg-rose-50 text-rose-600 rounded-xl flex items-center justify-center text-xl mb-4\">\n        <i class=\"fas fa-wallet\"></i>\n      </div>\n      <h3 class=\"font-semibold text-slate-800 mb-2\">Multi-currency Wallet</h3>\n      <p class=\"text-slate-500 text-sm\">Hold KES, USD, CDF and more in your account with instant visibility.</p>\n    </div>\n        <div class=\"bg-white border border-slate-100 rounded-2xl p-6 hover:shadow-md transition-shadow\">\n      <div class=\"w-12 h-12 bg-slate-50 text-slate-600 rounded-xl flex items-center justify-center text-xl mb-4\">\n        <i class=\"fas fa-code\"></i>\n      </div>\n      <h3 class=\"font-semibold text-slate-800 mb-2\">REST API</h3>\n      <p class=\"text-slate-500 text-sm\">Full API access to build custom payment flows into your product.</p>\n    </div>\n      </div>\n</section>\n\n<!-- Pricing -->\n<section id=\"pricing\" class=\"bg-slate-50 border-y border-slate-100 py-20\">\n  <div class=\"max-w-3xl mx-auto px-4 text-center\">\n    <h2 class=\"text-3xl font-extrabold text-slate-900 mb-3\">Simple, transparent pricing</h2>\n    <p class=\"text-slate-500 mb-10\">No monthly fees. Pay only when you receive a payment.</p>\n    <div class=\"max-w-sm mx-auto\">\n      <div class=\"bg-white rounded-2xl border-2 border-brand-600 p-10 text-center shadow-lg\">\n        <div class=\"text-5xl mb-4\">💸</div>\n        <div class=\"text-4xl font-extrabold text-brand-600 mb-2\">Flat Fee</div>\n        <div class=\"font-bold text-slate-800 text-lg mb-1\">Simple pricing — all payment methods</div>\n        <div class=\"text-sm text-slate-400\">We only deduct a flat processing fee</div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- CTA -->\n<section class=\"max-w-3xl mx-auto px-4 py-20 text-center\">\n  <h2 class=\"text-3xl font-extrabold text-slate-900 mb-4\">Ready to start accepting payments?</h2>\n  <p class=\"text-slate-500 mb-8\">Join hundreds of merchants already using Xdigitex Pay.</p>\n  <a href=\"https://pay.xdigitex.space/register\" class=\"bg-brand-600 hover:bg-brand-700 text-white font-bold px-10 py-4 rounded-xl text-lg transition-colors inline-block\">\n    Create Free Account →\n  </a>\n</section>\n\n<footer class=\"border-t border-slate-100 py-6 text-center text-sm text-slate-400\">\n  © 2026 Xdigitex Pay. All rights reserved.\n  <span class=\"mx-2\">·</span>\n  <a href=\"https://pay.xdigitex.space/login\" class=\"hover:text-slate-600\">Sign In</a>\n  <span class=\"mx-2\">·</span>\n  <a href=\"https://pay.xdigitex.space/docs\" class=\"hover:text-slate-600\">API Docs</a>\n</footer>\n\n\n</body></html>",
